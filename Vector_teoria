#include <iostream>
using namespace std;
class cvector {
public:
    cvector(int longi);
    ~cvector();
    void expansion();
    void push_back(int num);
    void push_front(int num);
    void pop_back();
    void pop_front();
    int operator [](int i);
    void impresion();



private:
    int* arr;
    unsigned long size , nelem;
};


int cvector::operator[](int i) {
    return *(arr+i);// arr[i]

}
cvector::cvector(int longi) {
    size = longi;
    arr = new int[size];
    nelem = 0;
}

cvector:: ~cvector() {
    delete[]arr;
}

void cvector::expansion() {
    int* p = new int[size * 2];

    for (int i = 0; i < size; i++) {
        p[i] = arr[i];
    }
    delete [] arr;
    arr = p;
    size = size * 2;
}

void cvector::push_back(int num){
    if (nelem == size) {
        expansion();
    }
    arr[nelem] = num; // arr[0]=1
    nelem++;
}
void cvector::push_front(int num) {
    if (nelem == size) {
        expansion();
    }
    for (int i = nelem; i > 0; i--) {
        arr[i] = arr[i - 1];
    }
    arr[0] = num;
    nelem++;
}
void cvector::pop_back() {
    if (nelem == 0) {
        cout << "Esta vacio papi";
        return;
    }
    nelem--;
}
void cvector::pop_front() {
    if (nelem == 0) return;
    for (int i = 0; i < nelem; i++) {
        arr[i] = arr[i + 1];
    }
    nelem--;

}
void cvector::impresion() {
    for (int i = 0; i < nelem; i++) {
        cout << "[" << arr[i] << "]";
    }
}


int main()
{
    cvector v(3);
    v.push_back(1);
    v.push_front(0);
    v.push_back(2);
    v.impresion();


}
